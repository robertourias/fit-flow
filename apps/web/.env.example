# ─────────────────────────────────────────────
# apps/web — variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# Variáveis NEXT_PUBLIC_* são expostas ao browser.
# ─────────────────────────────────────────────

# URL da API NestJS acessível pelo browser (host) — usada no bundle e por apiFetch
# no cliente. Sempre http://localhost:3001, em Docker ou fora dele.
NEXT_PUBLIC_API_URL=http://localhost:3001

# URL da API usada por código server-side (proxy BFF, Server Components).
# Fora do Docker: omitir (cai no fallback NEXT_PUBLIC_API_URL=http://localhost:3001).
# Dentro do Docker Compose: http://api:3001 (hostname interno, não localhost).
# API_INTERNAL_URL=http://api:3001

# Supabase — URL pública da instância local (via Docker Compose)
# Produção: use a URL fornecida pelo dashboard do Supabase cloud
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321

# Chave anônima do Supabase (segura para o browser — acesso restrito pelas RLS policies)
# Local: obtenha via `supabase status` ou no Studio em http://localhost:54323
# Produção: use a chave anon do dashboard do Supabase cloud
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key-local>
