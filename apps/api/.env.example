# ─────────────────────────────────────────────
# apps/api — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores.
# ─────────────────────────────────────────────

# Porta do servidor NestJS
# Railway injeta PORT automaticamente em produção
PORT=3001

# Ambiente de execução
NODE_ENV=development

# Connection string do PostgreSQL via Prisma
# Local (dentro do Docker Compose): hostname é o nome do serviço Docker
# Local (fora do Docker, Supabase CLI): postgresql://postgres:postgres@localhost:5432/postgres
# Produção (Supabase cloud): obtenha em Project Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres

# URL do Redis (BullMQ + cache)
# Local (dentro do Docker Compose): redis://redis:6379
# Local (fora do Docker): redis://localhost:6379
# Produção (Railway): variável fornecida pelo painel
REDIS_URL=redis://redis:6379

# Supabase — chave de serviço (acesso admin, nunca expor ao browser)
# Local: obtenha via `supabase status` ou no Studio em http://localhost:54323
# Produção: use a service_role key do dashboard do Supabase cloud
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key-local>
