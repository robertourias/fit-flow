# Turbo Remote Cache (opcional — habilitar para builds incrementais em CI)
TURBO_TOKEN=<seu-token-turbo-remote-cache>
TURBO_TEAM=<seu-team-slug>

# ─── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fitflow
POSTGRES_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── API (NestJS) ──────────────────────────────────────────────────────────────
NODE_ENV=development
# Migrations: defina 1 para pular em réplicas de leitura
SKIP_MIGRATIONS=0

# ─── E-mail (BullMQ workers) ───────────────────────────────────────────────────
# Em dev usa maildev (profile: tools); em prod configura com seu provedor SMTP
MAIL_HOST=maildev
MAIL_PORT=1025
MAIL_FROM=noreply@fitflow.local

# ─── Web (Next.js) ─────────────────────────────────────────────────────────────
# URL da API acessível pelo browser (não pela rede interna Docker)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Local: hostname do serviço dentro do Docker Compose (porta 54321)
# Produção: URL do projeto no dashboard do Supabase cloud
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key-local>

# Chave de serviço — nunca expor ao browser, usar apenas no backend
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key-local>

# Segredo usado para assinar os JWTs do Supabase Auth
SUPABASE_JWT_SECRET=<supabase-jwt-secret-local>

# ─── Portas dos serviços Docker (sobrescreva se houver conflito no host) ────────
WEB_PORT=3000
API_PORT=3001
SUPABASE_API_PORT=54321
SUPABASE_STUDIO_PORT=54323
